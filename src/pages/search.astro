---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { SearchPanel } from '../components/SearchPanel';
---

<BaseLayout title="Search — Vansha">
  <Navbar slot="header" />

  <section class="search-page">
    <div class="search-page-header">
      <div class="container">
        <h1>Search Records</h1>
        <p>Find family members by name, location, or other details.</p>
      </div>
    </div>
    <div class="container">
      <SearchPanel client:load />
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .search-page {
    min-height: calc(100vh - 56px);
    background: var(--color-bg);
  }

  .search-page-header {
    background: #ffffff;
    color: var(--color-text);
    padding: 1.25rem 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .search-page-header h1 {
    color: var(--color-text);
    font-size: 1.5rem;
    margin-bottom: 0.15rem;
  }

  .search-page-header p {
    color: var(--color-text-light);
    font-size: 0.875rem;
  }
</style>

<style is:global>
  /* Search styles */
  .search-panel {
    padding-bottom: 2.5rem;
  }

  .search-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .search-input-wrap {
    flex: 1;
    position: relative;
    min-width: 280px;
  }

  .search-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-light);
    pointer-events: none;
  }

  .search-input {
    width: 100%;
    padding: 0.65rem 2.5rem 0.65rem 2.75rem;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    font-size: 0.9375rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    background: var(--color-bg);
  }

  .search-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(24, 119, 242, 0.2);
    background: #fff;
  }

  .search-clear {
    position: absolute;
    right: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    font-size: 1.25rem;
    color: var(--color-text-light);
    padding: 0.25rem;
    border-radius: 50%;
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .search-clear:hover {
    background: #E4E6EB;
    color: var(--color-text);
  }

  .search-filters {
    display: flex;
    gap: 0.5rem;
  }

  .search-filters select {
    padding: 0.65rem 0.85rem;
    border: 1px solid var(--color-border);
    border-radius: 20px;
    background: var(--color-bg);
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.875rem;
  }

  .search-filters select:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(24, 119, 242, 0.2);
  }

  .search-meta {
    color: var(--color-text-light);
    font-size: 0.8125rem;
    margin-bottom: 1.25rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--color-border);
  }

  .search-results {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .search-result {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.85rem 1rem;
    text-decoration: none;
    color: var(--color-text);
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .search-result:hover {
    text-decoration: none;
    background: var(--color-bg);
    border-color: var(--color-primary-light);
  }

  .result-avatar {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1rem;
    color: #fff;
    background: var(--color-primary);
    flex-shrink: 0;
    overflow: hidden;
  }

  .result-avatar.gender-male {
    background: #1877F2;
  }

  .result-avatar.gender-female {
    background: #F3425F;
  }

  .result-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .result-info {
    flex: 1;
  }

  .result-info h3 {
    font-size: 1rem;
    margin-bottom: 0.1rem;
    color: var(--color-text);
  }

  .result-maiden {
    font-size: 0.75rem;
    color: var(--color-text-light);
    font-style: italic;
  }

  .result-details {
    display: flex;
    gap: 0.35rem;
    font-size: 0.75rem;
    color: var(--color-text-light);
    margin-top: 0.2rem;
  }

  .result-place {
    margin-left: 0.5rem;
  }

  .result-bio {
    font-size: 0.8125rem;
    color: var(--color-text-light);
    margin-top: 0.25rem;
    line-height: 1.4;
  }

  .result-arrow {
    font-size: 1.25rem;
    color: var(--color-text-light);
    transition: transform 0.2s;
  }

  .search-result:hover .result-arrow {
    transform: translateX(4px);
    color: var(--color-primary);
  }

  .search-empty {
    text-align: center;
    padding: 3rem 2rem;
    background: #fff;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .search-empty h3 {
    margin-bottom: 0.5rem;
  }

  .search-empty p {
    color: var(--color-text-light);
  }

  @media (max-width: 640px) {
    .search-filters {
      width: 100%;
    }

    .search-filters select {
      flex: 1;
    }
  }
</style>
