---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import { PersonForm } from '../components/PersonForm';
---

<BaseLayout title="Add Person — Vansha">
  <Navbar slot="header" />

  <section class="form-page">
    <div class="form-page-header">
      <div class="container">
        <h1>Add a Family Member</h1>
        <p>Fill in the details below to add someone to your family tree.</p>
      </div>
    </div>
    <div class="container">
      <PersonForm client:load />
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .form-page {
    min-height: calc(100vh - 56px);
    background: var(--color-bg);
  }

  .form-page-header {
    background: #ffffff;
    color: var(--color-text);
    padding: 1.25rem 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .form-page-header h1 {
    color: var(--color-text);
    font-size: 1.5rem;
    margin-bottom: 0.15rem;
  }

  .form-page-header p {
    color: var(--color-text-light);
    font-size: 0.875rem;
  }
</style>

<style is:global>
  /* Form styles */
  .person-form {
    max-width: 680px;
    margin: 0 auto;
    padding-bottom: 3rem;
  }

  .form-success {
    background: #E7F3E8;
    color: #1E7E34;
    padding: 0.85rem 1rem;
    border-radius: var(--radius-sm);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid #C3E6CB;
    font-size: 0.9375rem;
  }

  .form-success a {
    color: #1E7E34;
    font-weight: 600;
    margin-left: auto;
  }

  .form-section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    margin-bottom: 1.25rem;
    background: #fff;
    box-shadow: var(--shadow-sm);
  }

  .form-section legend {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 1rem;
    color: var(--color-text);
    padding: 0 0.5rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.85rem;
    margin-bottom: 0.85rem;
  }

  .form-row:last-child {
    margin-bottom: 0;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .form-group label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.6rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: 0.9375rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    background: var(--color-bg);
    color: var(--color-text);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px rgba(24, 119, 242, 0.2);
    background: #fff;
  }

  .form-group textarea {
    resize: vertical;
    min-height: 100px;
  }

  .form-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 0.5rem;
  }

  @media (max-width: 640px) {
    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
