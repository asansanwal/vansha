---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { PersonForm } from '../../components/PersonForm';
import { getDefaultTree } from '../../lib/store';

export function getStaticPaths() {
  const tree = getDefaultTree();
  return Object.keys(tree.persons).map((id) => ({
    params: { id },
  }));
}

const { id } = Astro.params;
---

<BaseLayout title={`Edit — Vansha`}>
  <Navbar slot="header" />

  <section class="form-page">
    <div class="form-page-header">
      <div class="container">
        <h1>Edit Profile</h1>
        <p>Update the details for this family member.</p>
      </div>
    </div>
    <div class="container">
      <PersonForm editPersonId={id} client:load />
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .form-page {
    min-height: calc(100vh - 56px);
    background: var(--color-bg);
  }

  .form-page-header {
    background: #ffffff;
    color: var(--color-text);
    padding: 1.25rem 0;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }

  .form-page-header h1 {
    color: var(--color-text);
    font-size: 1.5rem;
    margin-bottom: 0.15rem;
  }

  .form-page-header p {
    color: var(--color-text-light);
    font-size: 0.875rem;
  }
</style>
