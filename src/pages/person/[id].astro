---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { PersonProfile } from '../../components/PersonProfile';
import { getDefaultTree } from '../../lib/store';

export function getStaticPaths() {
  const tree = getDefaultTree();
  return Object.keys(tree.persons).map((id) => ({
    params: { id },
  }));
}

const { id } = Astro.params;
---

<BaseLayout title={`Profile — Vansha`}>
  <Navbar slot="header" />

  <section class="profile-page">
    <div class="container">
      <PersonProfile personId={id!} client:load />
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .profile-page {
    padding: 1.5rem 0 3rem;
    background: var(--color-bg);
  }
</style>

<style is:global>
  /* Profile styles */
  .profile-not-found {
    text-align: center;
    padding: 4rem 2rem;
    background: #fff;
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
  }

  .profile-not-found h2 {
    margin-bottom: 0.5rem;
  }

  .profile-not-found p {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  .profile-header {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    padding: 1.5rem;
    background: #fff;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border);
  }

  .profile-avatar-large {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 4px solid var(--color-primary);
  }

  .profile-avatar-large img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-large-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    font-weight: 700;
    color: #fff;
    background: var(--color-primary);
  }

  .avatar-large-placeholder.gender-male {
    background: #1877F2;
  }

  .avatar-large-placeholder.gender-female {
    background: #F3425F;
  }

  .profile-header-info h1 {
    font-size: 1.75rem;
    margin-bottom: 0.2rem;
    color: var(--color-text);
  }

  .profile-maiden {
    color: var(--color-text-light);
    font-style: italic;
    margin-bottom: 0.5rem;
    font-size: 0.9375rem;
  }

  .profile-dates-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-bottom: 0.65rem;
  }

  .profile-date {
    font-size: 0.875rem;
    color: var(--color-text-light);
  }

  .profile-bio {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text);
    max-width: 560px;
  }

  .profile-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .profile-section {
    padding: 1.25rem;
    background: #fff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .profile-section h2 {
    font-size: 1.1rem;
    margin-bottom: 0.85rem;
    padding-bottom: 0.4rem;
    border-bottom: 2px solid var(--color-primary);
    color: var(--color-text);
  }

  .profile-empty {
    color: var(--color-text-light);
    font-style: italic;
    font-size: 0.875rem;
  }

  /* Family Members */
  .family-connections {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .family-member {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.6rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.2s;
  }

  .family-member:hover {
    background: var(--color-bg);
    text-decoration: none;
  }

  .fm-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.8rem;
    color: #fff;
    background: var(--color-primary);
    flex-shrink: 0;
  }

  .fm-avatar.gender-male {
    background: #1877F2;
  }

  .fm-avatar.gender-female {
    background: #F3425F;
  }

  .fm-info {
    display: flex;
    flex-direction: column;
  }

  .fm-label {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-light);
    font-weight: 600;
  }

  .fm-name {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.875rem;
  }

  .fm-dates {
    font-size: 0.75rem;
    color: var(--color-text-light);
  }

  /* Timeline */
  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.75rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: var(--color-primary);
  }

  .timeline-item {
    position: relative;
    padding-bottom: 1.25rem;
    display: flex;
    gap: 0.75rem;
  }

  .timeline-icon {
    position: absolute;
    left: -2rem;
    top: 0;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    background: #fff;
    border: 2px solid var(--color-primary);
    border-radius: 50%;
    z-index: 1;
  }

  .timeline-content h4 {
    font-size: 0.9375rem;
    color: var(--color-text);
    margin-bottom: 0.15rem;
  }

  .timeline-date,
  .timeline-place {
    font-size: 0.75rem;
    color: var(--color-text-light);
    display: block;
  }

  .timeline-content p {
    font-size: 0.8125rem;
    color: var(--color-text);
    margin-top: 0.2rem;
  }

  /* Profile Actions */
  .profile-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .profile-header {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .profile-dates-row {
      justify-content: center;
    }

    .profile-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
