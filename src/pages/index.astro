---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Vansha — Discover Your Family Heritage">
  <Navbar slot="header" />

  <!-- Hero Section -->
  <section class="hero" id="hero">
    <canvas id="hero-canvas"></canvas>
    <div class="hero-overlay">
      <div class="container hero-content">
        <h1>Discover Your<br />Family Story</h1>
        <p>Build your family tree, explore your ancestry, and preserve the memories that connect generations.</p>
        <div class="hero-actions">
          <a href="/tree" class="btn btn-accent">View Family Tree</a>
          <a href="/add" class="btn btn-secondary btn-hero-secondary">Add Someone</a>
        </div>
      </div>
    </div>
  </section>

  <script>
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    const hero = document.getElementById('hero') as HTMLElement;
    const ctx = canvas.getContext('2d')!;

    let W = 0, H = 0;
    let mouse = { x: -1000, y: -1000 };
    const MOUSE_RADIUS = 120;

    interface Tile {
      x: number; y: number; w: number; h: number;
      baseY: number; fallDelay: number; fallen: boolean;
      vy: number; rotation: number; vr: number;
      opacity: number; color: string; shape: number;
      swayOffset: number; swaySpeed: number;
      mouseScale: number; mouseGlow: number;
    }

    const tiles: Tile[] = [];
    let startTime = 0;

    const LEAF_COLORS = [
      'rgba(255,255,255,0.12)',
      'rgba(255,255,255,0.08)',
      'rgba(255,255,255,0.15)',
      'rgba(200,230,255,0.10)',
      'rgba(180,220,255,0.12)',
      'rgba(100,200,255,0.08)',
    ];

    function resize() {
      const rect = hero.getBoundingClientRect();
      W = rect.width;
      H = rect.height;
      canvas.width = W * devicePixelRatio;
      canvas.height = H * devicePixelRatio;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
    }

    function initTiles() {
      tiles.length = 0;
      const cols = Math.ceil(W / 40);
      const rows = Math.ceil(H / 40);
      const totalTiles = cols * rows;
      const count = Math.min(Math.floor(totalTiles * 0.35), 200);

      for (let i = 0; i < count; i++) {
        const size = 10 + Math.random() * 28;
        tiles.push({
          x: Math.random() * W,
          y: -size - Math.random() * H * 1.5,
          w: size,
          h: size * (0.6 + Math.random() * 0.5),
          baseY: 0,
          fallDelay: Math.random() * 4,
          fallen: false,
          vy: 18 + Math.random() * 30,
          rotation: Math.random() * Math.PI * 2,
          vr: (Math.random() - 0.5) * 1.5,
          opacity: 0.4 + Math.random() * 0.6,
          color: LEAF_COLORS[Math.floor(Math.random() * LEAF_COLORS.length)],
          shape: Math.floor(Math.random() * 4),
          swayOffset: Math.random() * Math.PI * 2,
          swaySpeed: 0.5 + Math.random() * 1.5,
          mouseScale: 1,
          mouseGlow: 0,
        });
      }
    }

    function drawLeaf(t: Tile) {
      ctx.save();
      ctx.translate(t.x + t.w / 2, t.y + t.h / 2);
      ctx.rotate(t.rotation);
      ctx.globalAlpha = t.opacity;

      const glow = t.mouseGlow;
      if (glow > 0) {
        ctx.shadowColor = 'rgba(255,255,255,' + (glow * 0.5) + ')';
        ctx.shadowBlur = 12 * glow;
      }

      const s = t.mouseScale;
      ctx.scale(s, s);
      const hw = t.w / 2, hh = t.h / 2;

      ctx.fillStyle = t.color;
      ctx.strokeStyle = 'rgba(255,255,255,' + (0.15 + glow * 0.25) + ')';
      ctx.lineWidth = 0.8;

      switch (t.shape) {
        case 0: // Leaf shape
          ctx.beginPath();
          ctx.moveTo(0, -hh);
          ctx.bezierCurveTo(hw * 1.2, -hh * 0.5, hw * 1.2, hh * 0.5, 0, hh);
          ctx.bezierCurveTo(-hw * 1.2, hh * 0.5, -hw * 1.2, -hh * 0.5, 0, -hh);
          ctx.fill();
          ctx.stroke();
          // leaf vein
          ctx.beginPath();
          ctx.moveTo(0, -hh * 0.8);
          ctx.lineTo(0, hh * 0.8);
          ctx.strokeStyle = 'rgba(255,255,255,' + (0.1 + glow * 0.15) + ')';
          ctx.lineWidth = 0.5;
          ctx.stroke();
          break;
        case 1: // Small tree silhouette
          ctx.beginPath();
          ctx.moveTo(0, -hh);
          ctx.lineTo(hw * 0.8, hh * 0.3);
          ctx.lineTo(hw * 0.3, hh * 0.3);
          ctx.lineTo(hw * 0.3, hh);
          ctx.lineTo(-hw * 0.3, hh);
          ctx.lineTo(-hw * 0.3, hh * 0.3);
          ctx.lineTo(-hw * 0.8, hh * 0.3);
          ctx.closePath();
          ctx.fill();
          ctx.stroke();
          break;
        case 2: // Diamond / seed
          ctx.beginPath();
          ctx.moveTo(0, -hh);
          ctx.lineTo(hw * 0.6, 0);
          ctx.lineTo(0, hh);
          ctx.lineTo(-hw * 0.6, 0);
          ctx.closePath();
          ctx.fill();
          ctx.stroke();
          break;
        case 3: // Circle / fruit
          ctx.beginPath();
          ctx.arc(0, 0, Math.min(hw, hh) * 0.7, 0, Math.PI * 2);
          ctx.fill();
          ctx.stroke();
          break;
      }

      ctx.restore();
    }

    function animate(ts: number) {
      if (!startTime) startTime = ts;
      const elapsed = (ts - startTime) / 1000;
      const dt = Math.min(1 / 30, 1 / 60);

      ctx.clearRect(0, 0, W, H);

      for (const t of tiles) {
        if (elapsed < t.fallDelay) continue;

        // Falling
        t.y += t.vy * dt;
        t.rotation += t.vr * dt;

        // Gentle sway
        t.x += Math.sin(elapsed * t.swaySpeed + t.swayOffset) * 0.4;

        // Recycle tiles that fall off screen
        if (t.y > H + t.h * 2) {
          t.y = -t.h - Math.random() * 80;
          t.x = Math.random() * W;
          t.rotation = Math.random() * Math.PI * 2;
        }

        // Mouse interaction
        const cx = t.x + t.w / 2;
        const cy = t.y + t.h / 2;
        const dx = cx - mouse.x;
        const dy = cy - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);

        if (dist < MOUSE_RADIUS) {
          const factor = 1 - dist / MOUSE_RADIUS;
          // Push away from mouse
          const pushStrength = factor * 3;
          t.x += (dx / dist) * pushStrength;
          t.y += (dy / dist) * pushStrength;
          // Spin faster near mouse
          t.vr += factor * 0.3 * Math.sign(t.vr || 1);
          // Scale up and glow
          t.mouseScale += (1 + factor * 0.5 - t.mouseScale) * 0.15;
          t.mouseGlow += (factor - t.mouseGlow) * 0.15;
        } else {
          t.mouseScale += (1 - t.mouseScale) * 0.08;
          t.mouseGlow += (0 - t.mouseGlow) * 0.08;
        }

        // Dampen spin
        t.vr *= 0.998;

        drawLeaf(t);
      }

      requestAnimationFrame(animate);
    }

    function onMouseMove(e: MouseEvent) {
      const rect = hero.getBoundingClientRect();
      mouse.x = e.clientX - rect.left;
      mouse.y = e.clientY - rect.top;
    }

    function onMouseLeave() {
      mouse.x = -1000;
      mouse.y = -1000;
    }

    function onTouchMove(e: TouchEvent) {
      const rect = hero.getBoundingClientRect();
      const touch = e.touches[0];
      mouse.x = touch.clientX - rect.left;
      mouse.y = touch.clientY - rect.top;
    }

    resize();
    initTiles();
    hero.addEventListener('mousemove', onMouseMove);
    hero.addEventListener('mouseleave', onMouseLeave);
    hero.addEventListener('touchmove', onTouchMove, { passive: true });
    hero.addEventListener('touchend', onMouseLeave);
    window.addEventListener('resize', () => { resize(); initTiles(); });
    requestAnimationFrame(animate);
  </script>

  <!-- Features Section -->
  <section class="features">
    <div class="container">
      <h2 class="section-title">Explore Your Heritage</h2>
      <p class="section-subtitle">Vansha helps you build, manage, and explore your family tree with powerful tools and a beautiful interface.</p>
      <div class="features-grid">
        <div class="feature card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3>Build Your Tree</h3>
          <p>Add family members and connect relationships — parents, children, and spouses — to create a rich family tree.</p>
        </div>
        <div class="feature card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h3>Search & Discover</h3>
          <p>Find family members by name, location, or life events. Uncover hidden connections across your family history.</p>
        </div>
        <div class="feature card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3>Record Life Events</h3>
          <p>Document births, marriages, milestones, and more. Preserve the stories that make your family unique.</p>
        </div>
        <div class="feature card">
          <div class="feature-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
          <h3>Visual Tree View</h3>
          <p>See your family history come to life with an interactive, visual family tree you can explore and navigate.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="stats">
    <div class="container stats-grid">
      <div class="stat">
        <span class="stat-number">&infin;</span>
        <span class="stat-label">Generations to Explore</span>
      </div>
      <div class="stat">
        <span class="stat-number">100%</span>
        <span class="stat-label">Private & Secure</span>
      </div>
      <div class="stat">
        <span class="stat-number">Free</span>
        <span class="stat-label">Forever</span>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta">
    <div class="container cta-content">
      <h2>Start Building Your Family Tree Today</h2>
      <p>Every family has a story worth telling. Begin yours now.</p>
      <a href="/add" class="btn btn-accent">Get Started</a>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(135deg, #1565C0 0%, #1877F2 50%, #4599FF 100%);
    min-height: 65vh;
    display: flex;
    position: relative;
    overflow: hidden;
  }

  #hero-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .hero-overlay {
    position: relative;
    width: 100%;
    display: flex;
    align-items: center;
    z-index: 2;
  }

  .hero-content {
    max-width: 620px;
    padding: 4rem 1rem;
  }

  .hero h1 {
    font-size: 3rem;
    color: #fff;
    margin-bottom: 1rem;
    line-height: 1.1;
    font-weight: 800;
  }

  .hero p {
    font-size: 1.2rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 2rem;
    max-width: 480px;
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero-actions .btn-accent {
    background: #42b72a;
    color: #fff;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    border-radius: var(--radius-sm);
    font-weight: 700;
  }

  .hero-actions .btn-accent:hover {
    background: #36a420;
  }

  .btn-hero-secondary {
    color: #fff;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    padding: 0.75rem 1.5rem;
    font-size: 1rem;
    font-weight: 600;
  }

  .btn-hero-secondary:hover {
    background: rgba(255, 255, 255, 0.3);
    color: #fff;
    text-decoration: none;
  }

  /* Features */
  .features {
    padding: 4rem 0;
    background: #fff;
  }

  .section-title {
    text-align: center;
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .section-subtitle {
    text-align: center;
    color: var(--color-text-light);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    font-size: 0.95rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
  }

  .feature {
    padding: 1.75rem;
    text-align: center;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .feature:hover {
    border-color: var(--color-primary-light);
  }

  .feature-icon {
    color: var(--color-primary);
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
  }

  .feature h3 {
    font-size: 1.1rem;
    margin-bottom: 0.4rem;
    color: var(--color-text);
  }

  .feature p {
    color: var(--color-text-light);
    font-size: 0.875rem;
    line-height: 1.5;
  }

  /* Stats */
  .stats {
    background: var(--color-primary);
    padding: 2.5rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 2.25rem;
    font-weight: 800;
    color: #fff;
    font-family: var(--font-heading);
  }

  .stat-label {
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.875rem;
  }

  /* CTA */
  .cta {
    padding: 4rem 0;
    text-align: center;
    background: #fff;
  }

  .cta-content h2 {
    font-size: 1.75rem;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .cta-content p {
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    font-size: 1rem;
  }

  .cta .btn-accent {
    padding: 0.75rem 2rem;
    font-size: 1rem;
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .hero h1 {
      font-size: 2.25rem;
    }

    .stats-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
